{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "skipLibCheck": true,
    "types": ["bun-types", "react", "react-dom"],
    "lib": ["ESNext", "DOM", "DOM.Iterable"]
  },
  "include": ["src", "test", "scripts"]
}
